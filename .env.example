# For quick local testing without PostgreSQL
USE_SQLITE=false

# Database
DB_NAME=footy_league
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Django
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Editor role — required to perform create/update/delete actions
EDITOR_SECRET=change-me-to-a-strong-secret
